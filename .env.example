# API (services/core) — copy to services/core/.env
DATABASE_URL=postgres://casino:casino@localhost:5432/casino
PORT=8080

# Min 32 characters in production
JWT_SECRET=dev-only-change-me-use-openssl-rand-hex-32

# Optional: separate signing key for player JWTs (defaults to JWT_SECRET if unset)
# PLAYER_JWT_SECRET=

# Redis — required for async webhooks + worker (local password matches docker-compose)
REDIS_URL=redis://:casino-redis-local@localhost:6379/0

ADMIN_CORS_ORIGINS=http://localhost:5173
PLAYER_CORS_ORIGINS=http://localhost:5174

# Webhook HMAC (optional in dev; required in prod)
# WEBHOOK_BLUEOCEAN_SECRET=
# WEBHOOK_FYSTACK_SECRET=

# BlueOcean-style iframe launch base (stub)
# GAME_LAUNCH_BASE_URL=https://your-blueocean-launch-endpoint.example/play

# API (services/core) — copy to services/core/.env
DATABASE_URL=postgres://casino:casino@localhost:5432/casino
PORT=9090

# Min 32 characters in production
JWT_SECRET=dev-only-change-me-use-openssl-rand-hex-32

# Optional: separate signing key for player JWTs (defaults to JWT_SECRET if unset)
# PLAYER_JWT_SECRET=

# Redis — used for the job worker + webhook queue (local password matches docker-compose).
# If Redis is down, the API still starts; webhooks process inline when the queue is unavailable.
REDIS_URL=redis://:casino-redis-local@localhost:6379/0

ADMIN_CORS_ORIGINS=http://localhost:5173
PLAYER_CORS_ORIGINS=http://localhost:5174

# Webhook HMAC (optional in dev; required in prod)
# WEBHOOK_BLUEOCEAN_SECRET=
# PassimPay + cashier — see services/core/.env.example (PAYMENT_PROVIDER, PASSIMPAY_*)

# Blue Ocean XAPI (see services/core/.env.example for full list)
# BLUEOCEAN_API_BASE_URL=
# BLUEOCEAN_API_LOGIN=
# BLUEOCEAN_API_PASSWORD=
# BLUEOCEAN_CURRENCY=EUR
# BLUEOCEAN_WALLET_SALT=
# MAINTENANCE_MODE=false
# DISABLE_GAME_LAUNCH=false

# CoinMarketCap (set in services/core/.env) — live crypto tickers on player footer
# COINMARKETCAP_API_KEY=

# Fingerprint: player-ui VITE_FINGERPRINT_PUBLIC_KEY (+ VITE_FINGERPRINT_REGION=eu if dashboard is EU); core FINGERPRINT_SECRET_API_KEY + matching FINGERPRINT_API_BASE_URL — see services/core/.env.example

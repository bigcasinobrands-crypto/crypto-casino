# Copy to .env — financial core (NestJS) modular monolith
FINANCIAL_CORE_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/financial_core?schema=public
FINANCIAL_CORE_PORT=3080
FINANCIAL_CORE_REDIS_URL=redis://127.0.0.1:6379/0
# Or reuse monorepo redis:
# REDIS_URL=redis://127.0.0.1:6379/0

# Fystack (settlement rail — never balance authority)
# FYSTACK_BASE_URL=
# FYSTACK_API_KEY=
# FYSTACK_API_SECRET=
# FYSTACK_WORKSPACE_ID=

# BlueOcean (game events — never balance authority)
# BLUEOCEAN_WALLET_SALT=
# WEBHOOK_BLUEOCEAN_SECRET=

# Internal JWT (admin / service-to-service)
# INTERNAL_JWT_SECRET=

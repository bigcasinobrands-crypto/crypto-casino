# =============================================================================
# Crypto Casino — core API (Render Web Service) environment template
# =============================================================================
# HOW TO USE:
#   1. Copy this file (Save As… download from repo, or duplicate locally).
#   2. Replace every CHANGE_ME / REPLACE_* placeholder with real values.
#   3. Paste keys into Render Dashboard → Environment, OR use "Add from .env"
#      (strip comments if your tool does not ignore them — Render usually accepts
#      KEY=value lines; remove # comment lines for bulk import if needed).
#   4. Never commit a filled copy to git.
#
# Supabase: use Direct connection URI + ?sslmode=require
# Vercel player: set VITE_PLAYER_API_ORIGIN to this API’s public URL after deploy.
# Vercel admin:  set VITE_ADMIN_API_ORIGIN to the same API URL.
# =============================================================================

# --- Core mode -----------------------------------------------------------
APP_ENV=production

# Render injects PORT; the Go server reads it. Uncomment only if Render docs require it.
# PORT=10000

# --- Database (Supabase Postgres) ----------------------------------------
# Paste full URI from Supabase → Connect → URI. Must include sslmode=require.
DATABASE_URL=postgresql://postgres:CHANGE_ME_DB_PASSWORD@db.CHANGE_ME_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# --- Crypto / JWT --------------------------------------------------------
# Minimum 32 characters. Generate: openssl rand -hex 32
# Must NOT contain: dev-only   change-me   (blocked when APP_ENV=production)
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32_minimum_thirty_two_chars

# Optional separate player signing key (defaults to JWT_SECRET if unset).
# PLAYER_JWT_SECRET=

# Production normally requires RS256 key file. Pick ONE approach:

# (A) Recommended: mount RSA PEM as Render Secret File, set path:
# JWT_RSA_PRIVATE_KEY_FILE=/etc/secrets/jwt_rsa.pem

# (B) Temporary: HS256 only (not ideal for long-term):
ALLOW_JWT_HS256_IN_PRODUCTION=true

# --- Redis (required when APP_ENV=production) ------------------------------
# Use Upstash (rediss://…) or Render Key Value / Redis — NOT localhost.
REDIS_URL=CHANGE_ME_rediss://default:password@xxx.upstash.io:6379

# --- CORS (exact origins, comma-separated, no trailing slashes) ------------
# Player SPA (Vercel): production + preview URLs as needed
PLAYER_CORS_ORIGINS=https://CHANGE_ME_PLAYER_DOMAIN,https://www.CHANGE_ME_PLAYER_DOMAIN

# Admin SPA (Vercel)
ADMIN_CORS_ORIGINS=https://CHANGE_ME_ADMIN_DOMAIN

# Optional: lock /v1/admin to office/VPN IPs (CIDR or IPs, comma-separated)
# ADMIN_IP_ALLOWLIST=

# --- Public URLs ---------------------------------------------------------
# Player site — email links, redirects (no trailing slash)
PUBLIC_PLAYER_URL=https://CHANGE_ME_PLAYER_DOMAIN

# This API’s public origin (Render URL or custom domain). No trailing slash.
# Example: https://crypto-casino-api.onrender.com
API_PUBLIC_BASE=https://CHANGE_ME_RENDER_API_HOST

# --- Webhooks (set when you use them) ------------------------------------
# WEBHOOK_BLUEOCEAN_SECRET=
# WEBHOOK_FYSTACK_SECRET=

# --- Optional integrations (see services/core/.env.example) ----------------
# FYSTACK_BASE_URL=
# FYSTACK_WORKSPACE_ID=
# FYSTACK_API_KEY=
# FYSTACK_API_SECRET=
# BLUEOCEAN_API_BASE_URL=
# BLUEOCEAN_API_LOGIN=
# BLUEOCEAN_API_PASSWORD=
# ...

# --- Turnstile (if player uses VITE_TURNSTILE_SITE_KEY) -------------------
# TURNSTILE_SECRET=

# --- SMTP (optional; otherwise email may be log-only) -------------------
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=

# --- Staff WebAuthn (admin MFA) — needs REDIS_URL + matching admin origins ----
# WEBAUTHN_RP_ID=your-admin-domain.com
# WEBAUTHN_RP_ORIGINS=https://your-admin-host

# --- Logging -------------------------------------------------------------
# LOG_FORMAT=json

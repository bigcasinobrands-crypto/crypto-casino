# Dev: Vite proxies /v1 to core API (default http://127.0.0.1:9090). Must match services/core `PORT`.
# DEV_API_PROXY=http://127.0.0.1:9090

# When the admin SPA is served without a /v1 proxy (static host, odd preview), set the core API origin
# (host + port only, or ending in /v1 — both work; paths in code are like /v1/admin/...).
# VITE_ADMIN_API_ORIGIN=http://127.0.0.1:9090
# VITE_ADMIN_API_ORIGIN=https://api.example.com/v1
#
# Vercel only (Edge middleware `middleware.ts`): if you do NOT set VITE_ADMIN_API_ORIGIN, set CORE_API_ORIGIN
# in the Vercel dashboard to the same HTTPS API base so POST/PATCH to /v1/* are proxied (avoids HTTP 405).
# CORE_API_ORIGIN=https://your-core.onrender.com
# If you cannot rebuild, set the same origin in `frontend/admin-console/index.html` as
# <meta name="admin-api-origin" content="https://api.example.com" /> (no /v1 suffix on host).

# Must match services/core WEBAUTHN_RP_ORIGINS — browser WebAuthn checks the SPA origin.
# For local Vite dev this is typically http://localhost:5173

# Dashboard demo data: true/1 = always demo; false/0 = always live API; unset = demo by default in `vite` dev only.
# For real Postgres-backed KPIs instead, keep this false/unset and use core `npm run seed:dashboard-kpis` with
# ALLOW_DASHBOARD_DEMO_SEED=1 (see services/core .env.example).
# VITE_ADMIN_DUMMY_DASHBOARD=false

# Base URL of the player-facing SPA (no trailing slash). Used by Bonus Hub → Player layout deep links
# and challenge editor links to /terms (generated Terms copy).
# Defaults to http://127.0.0.1:5174 if unset.
# VITE_PLAYER_UI_ORIGIN=http://127.0.0.1:5174
# VITE_PLAYER_APP_ORIGIN=http://localhost:5174

# Optional: handoff link on Support → player detail. Placeholders: {user_id} or {userId}
# VITE_SUPPORT_CRM_URL_TEMPLATE=https://help.example.com/user/{user_id}

# --- Pigmo-style header icons (optional, same semantics as player-ui) ---
# JSON map slot → absolute https URL — slots: search, menu, bell, message, user, wallet
# VITE_PIGMO_SHELL_ICONS={"search":"https://imagedelivery.net/…/…/public","menu":"…","bell":"…"}
# Or CF Images folder with files named search.webp, menu.webp, bell.webp (variants /public):
# VITE_PIGMO_SHELL_ICON_BASE=https://imagedelivery.net/ACCOUNT_HASH/your-folder-path

# --- Fingerprint Pro (if admin loads the identification agent — same workspace public key as player-ui)
# EU workspace: also set VITE_FINGERPRINT_REGION=eu
# VITE_FINGERPRINT_PUBLIC_KEY=
# VITE_FINGERPRINT_REGION=eu

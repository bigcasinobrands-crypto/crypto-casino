# Dev: Vite proxies /v1 to core API (default http://127.0.0.1:8080). If the API uses PORT=9090:
# DEV_API_PROXY=http://127.0.0.1:9090

# Base URL of the player-facing SPA (no trailing slash). Used by Bonus Hub → Player layout deep links.
# Defaults to same-origin protocol + 127.0.0.1:5174 if unset.
# VITE_PLAYER_UI_ORIGIN=http://127.0.0.1:5174
# VITE_PLAYER_APP_ORIGIN=http://localhost:5174

# Optional: handoff link on Support → player detail. Placeholders: {user_id} or {userId}
# VITE_SUPPORT_CRM_URL_TEMPLATE=https://help.example.com/user/{user_id}

# Copy to ".env.staging" in this folder (gitignored):
#   copy staging.env.example .env.staging
# Then set DEV_API_PROXY to your public core API URL and run: npm run dev:staging
#
# Recommended: proxy through Vite (same as local dev, no extra browser CORS setup).
# Use the same base URL you deploy the Go API to (https, no path).
#
DEV_API_PROXY=
#
# If you prefer the browser to call the API directly (like production Vercel), set this instead
# and leave DEV_API_PROXY unset. The API must list http://localhost:5174 in PLAYER_CORS_ORIGINS.
# VITE_PLAYER_API_ORIGIN=
#
# If the API uses httpOnly cookie sessions for players:
# VITE_PLAYER_CREDENTIALS=1

{
  "name": "crypto-casino",
  "private": true,
  "workspaces": ["frontend/*", "packages/*"],
  "scripts": {
    "dev:admin": "npm run dev -w @repo/admin-console",
    "dev:player": "npm run dev -w @repo/player-ui",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down",
    "build": "npm run build --workspaces --if-present",
    "build:admin": "npm run build -w @repo/admin-console",
    "build:player": "npm run build -w @repo/player-ui",
    "build:core": "node scripts/build-core.mjs",
    "dev:api": "node scripts/go-dev.mjs ./cmd/api",
    "dev:worker": "node scripts/go-dev.mjs ./cmd/worker"
  }
}
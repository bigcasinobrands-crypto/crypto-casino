DATABASE_URL=postgres://casino:casino@localhost:5432/casino
#
# --- Supabase (optional: same core app; swap DATABASE_URL) ---
# 1) Supabase Dashboard → your project → Connect (or Settings → Database).
# 2) Copy the Postgres URI (ORMs / "Direct connection" is best for `npm run migrate:core`).
# 3) Ensure the URL includes SSL, e.g. add `?sslmode=require` (or `&sslmode=require` if query params already exist).
# 4) Default DB name is usually `postgres`; user is often `postgres.<project-ref>` on the pooler — use the string Supabase shows you.
# 5) From repo root: `copy services\\core\\.env.example services\\core\\.env` then set DATABASE_URL and run `npm run migrate:core`, then `npm run dev:api`.
# Example shape (password from Supabase Database settings, not the anon key):
# DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.xxxxxxxxxxxxx.supabase.co:5432/postgres?sslmode=require
#
# Do NOT set in production unless you run goose migrations yourself — missing migrations cause player login session_failed.
# SKIP_DB_MIGRATIONS_ON_START=
#
PORT=9090
JWT_SECRET=dev-only-change-me-use-openssl-rand-hex-32
REDIS_URL=redis://:casino-redis-local@localhost:6379/0
# When set, Blue Ocean debits that advance bonus WR PUBLISH JSON to Redis channel wagering:player:{user_id}
# (see docs/blue-ocean-bonus-wagering.md). Optional: hub/wallet still work without subscribers.
ADMIN_CORS_ORIGINS=http://localhost:5173
# Optional; comma-separated IPs or CIDRs — restrict /v1/admin to VPN/office egress (trust X-Forwarded-For from your edge).
# ADMIN_IP_ALLOWLIST=203.0.113.0/24,198.51.100.5
# API Content-Security-Policy: off | report | enforce (empty = report when APP_ENV=production, else off)
# SECURITY_CSP_MODE=enforce
# HttpOnly cookies for player sessions (also set VITE_PLAYER_CREDENTIALS=1 on player-ui). CSRF double-submit uses cc_player_csrf + X-CSRF-Token (set automatically by playerFetch).
# PLAYER_COOKIE_AUTH=true
# PLAYER_COOKIE_SAMESITE=lax
# Omit access_token/refresh_token from JSON (cookies carry secrets; pair with credentialed player-ui). Requires PLAYER_COOKIE_AUTH (core refuses to start otherwise).
# PLAYER_COOKIE_OMIT_JSON_TOKENS=true
# Reject passwords in HIBP Pwned Passwords corpus on register / change / reset (optional; k-anonymity API; service stays up if HIBP errors).
# HIBP_CHECK_PASSWORDS=true
# Fingerprint Pro (legacy / optional). Unset or false = no fingerprint on auth or traffic.
# Set to 1/true to ignore stale REQUIRE_* / WITHDRAW_* on the host (forces both off at load time).
# DISABLE_FINGERPRINT_PLAYER_AUTH=1
# REQUIRE_FINGERPRINT_PLAYER_AUTH=false
# WITHDRAW_REQUIRE_FINGERPRINT=false
# FINGERPRINT_SECRET_API_KEY=
# FINGERPRINT_API_BASE_URL=
# Production requires JWT_RSA_PRIVATE_KEY_FILE for RS256; escape hatch only:
# ALLOW_JWT_HS256_IN_PRODUCTION=true
# Browser origins allowed to call /v1 (comma-separated). Include every player SPA URL (local + prod + each Vercel preview host).
# Each Vercel preview deploy gets a unique *.vercel.app hostname — either list them or allow previews with a wildcard (github.com/go-chi/cors):
# PLAYER_CORS_ORIGINS=https://crypto-casino-player.vercel.app,https://*.vercel.app,http://localhost:5174
PLAYER_CORS_ORIGINS=http://localhost:5174
# PLAYER_CORS_ORIGINS=https://your-player-site.vercel.app,https://*.vercel.app,http://localhost:5174
# Player JWT signing (must differ from JWT_SECRET in production — see ValidateProduction).
# PLAYER_JWT_SECRET=
#
# BlueOcean POST /v1/webhooks/blueocean — HMAC body verification (X-Webhook-Signature).
# APP_ENV=production requires this secret on Render. Generate: openssl rand -hex 32; use the same string in BlueOcean.
# Bootstrap-only (deploy before provider hands you webhooks): ALLOW_PRODUCTION_MISSING_BLUEOCEAN_WEBHOOK_SECRET=true
# (POST webhook returns 401 until WEBHOOK_BLUEOCEAN_SECRET is set — not an open endpoint).
# WEBHOOK_BLUEOCEAN_SECRET=
# ALLOW_PRODUCTION_MISSING_BLUEOCEAN_WEBHOOK_SECRET=
# Synthetic house ledger user for clearing legs (deposit inbound / withdrawal outbound mirrors). Migration 00069 seeds the default UUID.
# Override only if you duplicate this pattern in a forked schema.
# LEDGER_HOUSE_USER_ID=00000000-0000-4000-a000-000000000001

# --- PassimPay (crypto cashier) — never commit real API secrets ---
# Default when unset is passimpay (production then needs credentials below). Use none to boot API without PassimPay.
# PAYMENT_PROVIDER=passimpay
# PAYMENT_PROVIDER=none
# PASSIMPAY_API_BASE_URL=https://api.passimpay.io
# PASSIMPAY_PLATFORM_ID=
# PASSIMPAY_SECRET_KEY=
# PASSIMPAY_WEBHOOK_SECRET=
# PASSIMPAY_CALLBACK_BASE_URL=https://your-api.example.com
# PASSIMPAY_DEPOSIT_METHOD=h2h
# PASSIMPAY_WITHDRAWALS_ENABLED=true

# Player app URL for email links (verify / reset)
PUBLIC_PLAYER_URL=http://localhost:5174

# Public base URL of this API (no trailing slash). When set, bonus card images stored as /v1/uploads/...
# are returned to clients as https://your-api…/v1/uploads/... so the player app can load them when
# the UI is hosted on a different origin than the API. Also used when staff upload images in Bonus Hub.
# API_PUBLIC_BASE=https://api.example.com

# --- Blue Ocean Gaming (XAPI + seamless wallet) — never commit real secrets ---
#
# BO onboarding gives TWO passwords on the same sheet — do not confuse them:
#   • "Backoffice" / dashboard password — login to BO’s staff UI only. NEVER put this in env.
#   • "Api Password" (under Api Accesses) — this is BLUEOCEAN_API_PASSWORD for XAPI (getGameList, getGame, …).
# Using the Backoffice password in BLUEOCEAN_API_PASSWORD typically yields error=1 / "Invalid user details!"
# on getGame / launch even when Api Username matches.
#
# Map from BOG "Api and Backoffice accesses" sheet → env (XAPI base URL is usually a separate onboarding doc):
#   Api Username     → BLUEOCEAN_API_LOGIN   (often same string as Backoffice username)
#   Api Password     → BLUEOCEAN_API_PASSWORD (must be Api Accesses password, not Backoffice)
#   Agent id         → BLUEOCEAN_AGENT_ID
#   Currency         → BLUEOCEAN_CURRENCY
#   Multicurrency    → BLUEOCEAN_MULTICURRENCY (true / 1)
#   Salt Key         → BLUEOCEAN_WALLET_SALT (seamless wallet GET callback signature)
# Callback URL you register with BOG must match this app’s public API host, e.g.
#   https://YOUR_API_HOST/api/blueocean/callback
# Local dev over ngrok: tunnel PORT (default 9090), then `npm run ngrok:print` from repo root for API_PUBLIC_BASE + full callback URL.
# (see cmd/api route GET /api/blueocean/callback — no /v1 prefix). Whitelisted IPs are set on BOG’s side —
# your server’s outbound IP must match what they allow for staging/production API calls.
#
# XAPI is POST-only with application/x-www-form-urlencoded (not JSON). No trailing "?".
# Example staging host (from BOG / game-program):
# BLUEOCEAN_API_BASE_URL=https://stage.game-program.com/api/seamless/provider
# BLUEOCEAN_API_BASE_URL=https://YOUR_XAPI_ENDPOINT_FROM_BOG/
# BLUEOCEAN_API_LOGIN=
# BLUEOCEAN_API_PASSWORD=
# BLUEOCEAN_AGENT_ID=
# BLUEOCEAN_CURRENCY=EUR
# BLUEOCEAN_MULTICURRENCY=true
# BLUEOCEAN_LAUNCH_MODE=demo
# XAPI `userid` format: unset or empty = compact UUID (32 hex, no hyphens) — this is the default and matches most BO stagings.
# On Render, you usually do NOT need to set this; only set false if your operator requires dashed canonical UUIDs:
# BLUEOCEAN_USERID_NO_HYPHENS=true
# BLUEOCEAN_USERID_NO_HYPHENS=false
# Seamless wallet GET callback: key = SHA1(salt + canonical query without key)
# BLUEOCEAN_WALLET_SALT=
# When true, amount/bet/win query values that contain a decimal point are treated as major units (e.g. 0.25 → 25 minor). Whole-number params are still minor units.
# BLUEOCEAN_WALLET_FLOAT_AMOUNT_IS_MAJOR=false
# Optional curated game id_hash list (comma-separated) for featured rails
# BLUEOCEAN_FEATURED_ID_HASHES=
# Optional JSON: {"gameshows":["hash1"],"blackjack":["hash2"]}
# BLUEOCEAN_LOBBY_TAGS_JSON=
#
# Full catalog sync: getGameList usually returns one page. Default page size is 500; sync loops with limit+offset until a short page.
# Set to 0 to send a single request without paging (legacy / tiny catalogs).
# BLUEOCEAN_CATALOG_PAGE_SIZE=500
# If the API uses different paging keys, try: offset (default), page, or from
# BLUEOCEAN_CATALOG_PAGING=offset
# Prefix for relative thumbnail paths from the API (e.g. https://cdn.example.com)
# BLUEOCEAN_IMAGE_BASE_URL=
#
# Offline / local catalog (no outbound Blue Ocean — skips IP allowlist): path to JSON matching getGameList response body.
# Export once from a whitelisted machine or paste BO docs sample; then Sync catalog or restart API with ON_START.
# BLUEOCEAN_CATALOG_SNAPSHOT_PATH=data/blueocean-gamelist.json
# BLUEOCEAN_CATALOG_SNAPSHOT_ON_START=true
#
# --- Sportsbook (full BO sports product — not the same as a single virtual-sports “game” tile) ---
# BO’s onboarding doc usually gives a dedicated numeric game id for the sportsbook iframe. Set one of:
#   BLUEOCEAN_SPORTSBOOK_BOG_GAME_ID — passed to getGame/getGameDemo as gameid (no catalog row required).
#   BLUEOCEAN_SPORTSBOOK_GAME_ID — internal games.id row for the main sportsbook tile (our DB primary key).
# If BO documents a different XAPI method for sportsbook, set:
#   BLUEOCEAN_SPORTSBOOK_XAPI_METHOD — method name (replaces getGame/getGameDemo for /v1/sportsbook/launch).
# Optional extra form fields for that method (JSON object):
#   BLUEOCEAN_SPORTSBOOK_XAPI_EXTRA_JSON={"key":"value"}
# Without any of the above, /v1/sportsbook/context and /v1/sportsbook/launch fall back to the best catalog match
# in category=sports excluding game_type=virtual-sports (still may be wrong — prefer explicit ids from BO).
# BLUEOCEAN_SPORTSBOOK_BOG_GAME_ID=
# BLUEOCEAN_SPORTSBOOK_GAME_ID=
# BLUEOCEAN_SPORTSBOOK_XAPI_METHOD=
# BLUEOCEAN_SPORTSBOOK_XAPI_EXTRA_JSON=

# Kill switch / maintenance (player UI reads /health/operational)
# MAINTENANCE_MODE=false
# DISABLE_GAME_LAUNCH=false

# Geo stub for launch/play checks: ISO 3166-1 alpha-2 from edge, e.g. X-Geo-Country header
# BLOCKED_COUNTRY_CODES=

# Staff CRM handoff for Live Support button in admin
# SUPPORT_CRM_URL_TEMPLATE=https://help.example.com/user/{user_id}

# Cloudflare Turnstile (optional; when set, login/register require captcha_token)
# TURNSTILE_SECRET=

# SMTP (optional; without it, emails are logged to API stdout). Use Mailpit in docker-compose (port 1025).
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@localhost

# TERMS_VERSION=1
# PRIVACY_VERSION=1

# --- Fingerprint Pro (server — Secret API key from Dashboard → API keys → Server API; never expose to browsers)
# Used to fetch full identification / smart signals from requestId for ledger metadata + RiskService.
# EU workspace: use https://eu.api.fpjs.io (must match player-ui VITE_FINGERPRINT_REGION=eu). US default: https://api.fpjs.io
# FINGERPRINT_SECRET_API_KEY=
# FINGERPRINT_API_BASE_URL=https://api.fpjs.io
# REQUIRE_FINGERPRINT_PLAYER_AUTH — legacy opt-in (unset = false in all APP_ENV). ValidateProduction requires FINGERPRINT_SECRET_API_KEY when true.
# DISABLE_FINGERPRINT_PLAYER_AUTH=1 — forces both REQUIRE_* and WITHDRAW_REQUIRE_FINGERPRINT off (use if the host still has stale legacy vars).
# With APP_ENV=development, login/register/refresh/traffic/withdraw never reject missing fingerprint_request_id (unless WITHDRAW_REQUIRE_FINGERPRINT=true). Use APP_ENV=staging to test production-style rules locally.
# Override explicitly: true | false | 1 | 0
# REQUIRE_FINGERPRINT_PLAYER_AUTH=false
# When true, POST /v1/wallet/withdraw requires JSON fingerprint_request_id (player-ui sends it when VITE_FINGERPRINT_ENABLED=1 and VITE_FINGERPRINT_PUBLIC_KEY are set).
# WITHDRAW_REQUIRE_FINGERPRINT=false

# Logo.dev — token/chain logos for deposit UI (GET /v1/market/crypto-logo-urls). Publishable builds img.logo.dev URLs; secret is for server-only search APIs later.
# https://www.logo.dev/docs/logo-images/crypto
# LOGO_DEV_PUBLISHABLE_KEY=
# LOGO_DEV_SECRET_KEY=

# CoinMarketCap Pro — powers GET /v1/market/crypto-tickers (footer live prices + logos). Server-side only; never expose in the browser.
# https://coinmarketcap.com/api/documentation/
# COINMARKETCAP_API_KEY=
# (alias) CMC_API_KEY=

# Withdrawal fraud parameters (all in USD cents unless noted; 0 = no limit / no restriction)
# WITHDRAW_MAX_SINGLE_CENTS=50000        # max $500 per withdrawal
# WITHDRAW_DAILY_LIMIT_CENTS=200000      # max $2000 per user per 24h
# WITHDRAW_DAILY_COUNT_LIMIT=10          # max 10 withdrawals per user per 24h
# WITHDRAW_MIN_ACCOUNT_AGE_SEC=3600      # account must be 1h old before withdrawals

# Bonus engine — auto-forfeit when max-bet reject count reaches threshold (worker sweep; 0 = off)
# BONUS_MAX_BET_VIOLATIONS_AUTO_FORFEIT=3

# Casino challenges — set to 1/true to skip enqueueing Blue Ocean round jobs after wallet debit/credit (worker idle).
# CHALLENGE_INGEST_DISABLED=

# --- Vault (optional local; see security/vault/README.md) ---
# VAULT_ADDR=http://127.0.0.1:8200
# VAULT_TOKEN=dev-root-token
# Transit encrypt/decrypt for PII (see security/docs/epics/vault-transit-pii.md).
# Key name must match: vault write -f transit/keys/<name> (bootstrap defaults to player-pii).
# VAULT_TRANSIT_MOUNT=transit
# VAULT_TRANSIT_KEY_NAME=player-pii
# Optional: sets users.email_hmac on register / login backfill (internal/pii.EmailLookupHMACBytes); keep in Vault in production.
# PII_EMAIL_LOOKUP_SECRET=

# --- Logging (API + worker) ---
# text (default) | json — JSON enables log drains / alerting without parsing ad hoc
# LOG_FORMAT=json

# --- Staff WebAuthn / MFA (admin console) — requires REDIS_URL ---
# RP ID must match the host users sign in from (no port). Origins are comma-separated admin SPA origins.
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_RP_DISPLAY_NAME=Crypto Casino Admin
# WEBAUTHN_RP_ORIGINS=http://localhost:5173

# --- Oddin.gg Bifrost + operator callbacks (server secrets — never expose player JWTs) ---
# Iframe checklist + handoff template: docs/oddin-iframe-integration.md
# Player loads bootstrap from GET /v1/sportsbook/oddin/public-config when these three are set (no duplicate VITE_* required):
# ODDIN_ENABLED=1
# ODDIN_ENV=integration
# ODDIN_PUBLIC_BASE_URL=https://bifrost.integration.oddin.gg
# ODDIN_PUBLIC_SCRIPT_URL=https://bifrost.integration.oddin.gg/script.js
# Public brand token (same value Oddin gives for the Bifrost client; safe in browser — required for public-config):
# ODDIN_BRAND_TOKEN=
# Optional Bifrost UI defaults (also returned in public-config):
# ODDIN_THEME=
# ODDIN_DEFAULT_LANGUAGE=en
# ODDIN_DEFAULT_CURRENCY=USD
# ISO 3166-1 alpha-2 fallback when traffic has no country (many esports brands block US — try GB, MT, etc.)
# ODDIN_DEFAULT_COUNTRY=US
# ODDIN_DARK_MODE=true
# ODDIN_API_SECURITY_KEY=
# ODDIN_HASH_SECRET=
# ODDIN_TOKEN_TTL_SECONDS=2592000
# Comma-separated IPs for POST /v1/oddin/* (Oddin egress); empty = allow all.
# ODDIN_OPERATOR_IP_ALLOWLIST=108.128.47.233,3.1.190.49
#
# Optional: JSON array for the E-Sports submenu (id, label, page, logoUrl). Prefer an HTTPS logoUrl on every row from Oddin's Bifrost sports assets so icons match their dashboard; when logoUrl is omitted, the player app fills from bundled fallbacks if `page` matches (up to ~80 rows).
# Example (single line): [{"id":"overview","label":"Overview","page":""},{"id":"cs2","label":"Counter-Strike 2","page":"/cs2","logoUrl":"https://..."}]
# ODDIN_ESPORTS_NAV_JSON=
